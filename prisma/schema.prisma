generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
  locked
}

enum ProjectStatus {
  created
  deploying
  running
  stopped
  failed
  archived
}

enum DeploymentStatus {
  queued
  running
  success
  failed
  rolled_back
  cancelled
}

enum DatabaseEngine {
  postgresql
  mysql
  mariadb
  mongodb
  redis
  sqlite
}

enum DatabaseAccessMode {
  localhost_only
  allowlist
  public
}

enum BackupStatus {
  queued
  running
  success
  failed
}

enum ServiceStatus {
  unknown
  running
  stopped
  failed
}

enum NotificationType {
  info
  success
  warning
  error
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  passwordHash   String
  status         UserStatus @default(active)
  twoFactorOn    Boolean    @default(false)
  twoFactorSecret String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  roles          UserRole[]
  sessions       Session[]
  apiTokens      ApiToken[]
  projects       ProjectMember[]
  deployments    Deployment[]
  auditLogs      AuditLog[]
  databaseQueries DatabaseQuery[]
  terminalSessions TerminalSession[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshHash  String
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiToken {
  id          String   @id @default(cuid())
  userId      String
  name        String
  tokenHash   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  framework       String
  runtime         String        @default("node")
  nodeVersion     String        @default("lts")
  packageManager  String        @default("auto")
  installCommand  String?
  buildCommand    String?
  startCommand    String?
  workingDirectory String       @default(".")
  outputDirectory String?
  port            Int?
  domain          String?
  repositoryUrl   String?
  branch          String        @default("main")
  lastCommitHash  String?
  status          ProjectStatus @default(created)
  healthCheckUrl  String?
  autoDeploy      Boolean       @default(false)
  backupEnabled   Boolean       @default(true)
  pm2Name         String?
  logPath         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  envs            ProjectEnv[]
  deployments     Deployment[]
  domains         Domain[]
  backups         Backup[]
  members         ProjectMember[]
  metrics         ProjectMetric[]
}

model ProjectMember {
  projectId String
  userId    String
  role      String @default("developer")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model ProjectEnv {
  id        String   @id @default(cuid())
  projectId String
  key       String
  valueEnc  String
  masked    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
}

model Deployment {
  id             String           @id @default(cuid())
  projectId      String
  userId         String?
  status         DeploymentStatus @default(queued)
  source         String           @default("manual")
  commitHash     String?
  branch         String?
  startedAt      DateTime?
  finishedAt     DateTime?
  durationMs     Int?
  errorMessage   String?
  rollbackOfId   String?
  createdAt      DateTime         @default(now())

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  logs           DeploymentLog[]
}

model DeploymentLog {
  id           String   @id @default(cuid())
  deploymentId String
  level        String   @default("info")
  message      String
  step         String?
  createdAt    DateTime @default(now())

  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model Domain {
  id             String   @id @default(cuid())
  projectId      String?
  hostname       String   @unique
  rootDomain     String?
  dnsStatus      String   @default("unknown")
  sslEnabled     Boolean  @default(false)
  proxyType      String   @default("nginx")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  certificate    SslCertificate?
}

model SslCertificate {
  id          String   @id @default(cuid())
  domainId    String   @unique
  issuer      String   @default("letsencrypt")
  status      String   @default("unknown")
  notBefore   DateTime?
  expiresAt   DateTime?
  certPath    String?
  keyPath     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  domain      Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DatabaseServer {
  id             String             @id @default(cuid())
  name           String
  engine         DatabaseEngine
  host           String             @default("localhost")
  port           Int
  accessMode     DatabaseAccessMode @default(localhost_only)
  username       String?
  passwordEnc    String?
  status         ServiceStatus      @default(unknown)
  version        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  databases      ManagedDatabase[]
  users          DatabaseUser[]
  queries        DatabaseQuery[]
}

model ManagedDatabase {
  id              String         @id @default(cuid())
  serverId        String
  name            String
  owner           String?
  sizeBytes       BigInt?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  server          DatabaseServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model DatabaseUser {
  id           String         @id @default(cuid())
  serverId     String
  username     String
  passwordEnc  String?
  privileges   Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  server       DatabaseServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model DatabaseQuery {
  id           String         @id @default(cuid())
  serverId     String
  userId       String?
  databaseName String?
  queryHash    String
  queryMasked  String
  durationMs   Int?
  rowCount     Int?
  success      Boolean        @default(false)
  errorMessage String?
  createdAt    DateTime       @default(now())

  server       DatabaseServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model FirewallRule {
  id          String   @id @default(cuid())
  port        Int
  protocol    String   @default("tcp")
  action      String   @default("allow")
  sourceIp    String?
  description String?
  enabled     Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
}

model FilesAudit {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  path      String
  details   Json?
  createdAt DateTime @default(now())
}

model TerminalSession {
  id        String   @id @default(cuid())
  userId    String
  cwd       String?
  command   String?
  status    String   @default("created")
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ManagedService {
  id          String        @id @default(cuid())
  name        String        @unique
  unitName    String?
  status      ServiceStatus @default(unknown)
  enabled     Boolean       @default(false)
  lastCheckedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Backup {
  id          String       @id @default(cuid())
  projectId   String?
  type        String
  target      String       @default("local")
  path        String?
  encrypted   Boolean      @default(false)
  status      BackupStatus @default(queued)
  sizeBytes   BigInt?
  errorMessage String?
  createdAt   DateTime     @default(now())
  finishedAt  DateTime?

  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model BackupJob {
  id          String   @id @default(cuid())
  name        String
  schedule    String
  target      String   @default("local")
  retentionDays Int    @default(14)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(info)
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ServerMetric {
  id            String   @id @default(cuid())
  cpuUsage      Float?
  ramUsage      Float?
  diskUsage     Float?
  swapUsage     Float?
  loadAverage   Float?
  networkRx     BigInt?
  networkTx     BigInt?
  createdAt     DateTime @default(now())
}

model ProjectMetric {
  id            String   @id @default(cuid())
  projectId     String
  cpuUsage      Float?
  ramUsage      Float?
  restartCount  Int?
  uptimeSeconds Int?
  status        String?
  createdAt     DateTime @default(now())

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model SystemUpdate {
  id           String   @id @default(cuid())
  fromVersion  String?
  toVersion    String?
  status       String
  log          String?
  backupPath   String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
}

model InstalledApp {
  id          String   @id @default(cuid())
  name        String
  version     String?
  type        String?
  status      String   @default("installed")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CronTask {
  id          String   @id @default(cuid())
  name        String
  type        String
  schedule    String
  target      String?
  enabled     Boolean  @default(true)
  notify      Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String   @default("never_run")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
