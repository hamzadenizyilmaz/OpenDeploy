NODE_ENV=development
OPENDEPLOY_VERSION=v2.0.0-enterprise-ops

APP_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://127.0.0.1:4000
WEB_PORT=8080
API_PORT=4000
AGENT_PORT=4100
DNS_CLOUD_ADMIN_PORT=4310

DATABASE_URL=postgresql://opendeploy:opendeploy@localhost:5432/opendeploy
REDIS_URL=redis://localhost:6379
REDIS_TLS_CA_FILE=
REDIS_TLS_REJECT_UNAUTHORIZED=true

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters
SESSION_SECRET=change-me-session-secret-minimum-32-characters
AGENT_TOKEN=change-me-agent-token-minimum-32-characters
# Generate with: openssl rand -base64 32
OPENDEPLOY_ENCRYPTION_KEY=
OPENDEPLOY_ENVELOPE_PUBLIC_KEY=
OPENDEPLOY_ENVELOPE_PRIVATE_KEY=

OPENDEPLOY_ROOT=/opt/opendeploy
OPENDEPLOY_DATA=/var/lib/opendeploy
OPENDEPLOY_PROJECTS=/var/lib/opendeploy/projects
OPENDEPLOY_BACKUPS=/var/backups/opendeploy
OPENDEPLOY_LOGS=/var/log/opendeploy
OPENDEPLOY_AGENT_STRICT=false
OPENDEPLOY_PRISMA_QUERY_LOGS=false
OPENDEPLOY_GITHUB_REPO=hamzadenizyilmaz/OpenDeploy

DEFAULT_PROXY=nginx
DEFAULT_DOMAIN=
SSL_EMAIL=admin@example.com

# DNS Cloud mode: creartsoft, self-hosted
DNS_CLOUD_ENABLED=true
DNS_CLOUD_MODE=creartsoft
DNS_CLOUD_API_URL=https://dns.creartsoft.com/api/v1
DNS_CLOUD_ADMIN_URL=https://dns.creartsoft.com
DNS_CLOUD_DATABASE_URL=postgresql://opendeploy_dns:opendeploy_dns@localhost:5432/opendeploy_dns
DNS_CLOUD_REDIS_URL=redis://localhost:6379
DNS_CLOUD_STATE_FILE=/var/lib/opendeploy/dns-cloud-state.json
DNS_CLOUD_STATE_PERSISTENCE=true
DNS_CLOUD_JWT_SECRET=change-me-dns-cloud-jwt-secret-minimum-32-characters
DNS_CLOUD_INSTANCE_ID=opd_xxxxxxxxx
DNS_CLOUD_API_KEY=secure_generated_key
DNS_CLOUD_ADMIN_TOKEN=change-me-only-for-dns-cloud-admin-or-nameserver
DNS_CLOUD_ADMIN_BOOTSTRAP_TOKEN=change-me-only-for-registration-bootstrap
DNS_CLOUD_ENCRYPTION_KEY=
DNS_CLOUD_ENVELOPE_PUBLIC_KEY=
DNS_CLOUD_ENVELOPE_PRIVATE_KEY=
DNS_DEFAULT_NS1=dp-ns1.opendeploy.com
DNS_DEFAULT_NS2=dp-ns2.opendeploy.com
DNS_NAMESERVERS=dp-ns1.opendeploy.com,dp-ns2.opendeploy.com
DNS_BRAND_NAME=OpenDeploy DNS Cloud
DNS_BRAND_OWNER=Creart Soft

# Self-hosted DNS Cloud example:
# DNS_CLOUD_MODE=self-hosted
# DNS_CLOUD_API_URL=https://dns.example.com/api/v1
# DNS_CLOUD_ADMIN_URL=https://dns.example.com
# DNS_DEFAULT_NS1=ns1.example.com
# DNS_DEFAULT_NS2=ns2.example.com
# DNS_BRAND_NAME=MyDeploy DNS
# DNS_BRAND_OWNER=My Company

OPENDEPLOY_ADMIN_EMAIL=admin@example.com
OPENDEPLOY_ADMIN_PASSWORD=ChangeMeOnlyForLocalDev123!
OPENDEPLOY_ADMIN_NAME=OpenDeploy Owner
